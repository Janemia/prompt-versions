  },
  "homepage": "https://github.com/Janemia/prompt-versions#readme",
  "dependencies": {
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "boxen": "^7.1.0",
    "inquirer": "^9.2.0",
